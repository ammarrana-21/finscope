  <style>
    /* ===== NAVIGATION ===== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      height: var(--nav-height);
      background: rgba(6, 11, 24, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-subtle);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
      gap: var(--space-8);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-shrink: 0;
    }

    .logo-mark {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--color-accent), #45B7D1);
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 16px;
      color: var(--text-inverse);
      letter-spacing: -0.02em;
    }

    .logo-text {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: var(--text-xl);
      letter-spacing: -0.03em;
      color: var(--text-primary);
    }

    .logo-text span { color: var(--color-accent); }

    .nav-links {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      list-style: none;
      flex: 1;
    }

    .nav-links a {
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--text-secondary);
      transition: color var(--transition-fast), background var(--transition-fast);
    }

    .nav-links a:hover {
      color: var(--text-primary);
      background: var(--surface-glass-light);
    }

    .nav-links a.active { color: var(--color-accent); }

    .nav-cta { display: flex; align-items: center; gap: var(--space-3); }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      padding: var(--space-2);
      cursor: pointer;
    }

    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text-secondary);
      border-radius: 2px;
      transition: all var(--transition-base);
    }

    @media (max-width: 768px) {
      .nav-links, .nav-cta .btn-ghost { display: none; }
      .nav-hamburger { display: flex; }
    }

    /* Mobile Menu */
    .mobile-menu {
      display: none;
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--surface-0);
      z-index: 99;
      padding: var(--space-6);
      flex-direction: column;
      gap: var(--space-2);
      overflow-y: auto;
    }

    .mobile-menu.open { display: flex; }

    .mobile-menu a {
      padding: var(--space-4) var(--space-4);
      border-radius: var(--radius-md);
      font-size: var(--text-lg);
      font-weight: 500;
      color: var(--text-secondary);
      border: 1px solid transparent;
      transition: all var(--transition-fast);
    }

    .mobile-menu a:hover {
      color: var(--text-primary);
      background: var(--surface-2);
      border-color: var(--border-subtle);
    }

    /* ===== TICKER ===== */
    .ticker-bar {
      background: var(--surface-1);
      border-bottom: 1px solid var(--border-subtle);
      padding: var(--space-2) 0;
      overflow: hidden;
    }

    .ticker-track {
      display: flex;
      gap: var(--space-12);
      width: max-content;
      animation: ticker 40s linear infinite;
    }

    .ticker-track:hover { animation-play-state: paused; }

    .ticker-item {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      white-space: nowrap;
      font-size: var(--text-xs);
      font-family: var(--font-mono);
    }

    .ticker-label { color: var(--text-muted); }
    .ticker-value { color: var(--text-primary); font-weight: 500; }
    .ticker-delta { font-weight: 600; }
    .ticker-delta.up { color: var(--color-positive); }
    .ticker-delta.down { color: var(--color-danger); }
    .ticker-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--border-default); }

    /* ===== HERO ===== */
    .hero {
      padding: var(--space-20) 0 var(--space-16);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(0,212,170,0.07) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: center;
    }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: var(--space-10); }
      .hero-visual { order: -1; }
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      margin-bottom: var(--space-5);
    }

    .hero-eyebrow-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-accent);
      animation: pulse-glow 2s ease-in-out infinite;
    }

    .hero-eyebrow-text {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-accent);
    }

    .hero-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: var(--space-5);
    }

    .hero-subtitle {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: var(--space-8);
      max-width: 520px;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-wrap: wrap;
    }

    .hero-trust {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-top: var(--space-8);
      flex-wrap: wrap;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-xs);
      color: var(--text-muted);
    }

    .trust-icon {
      width: 14px;
      height: 14px;
      color: var(--color-accent);
    }

    /* Hero Visual - Live Dashboard Preview */
    .hero-visual {
      position: relative;
    }

    .dashboard-preview {
      background: var(--surface-2);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-2xl);
      padding: var(--space-6);
      box-shadow: var(--shadow-lg), 0 0 60px rgba(0,212,170,0.05);
      position: relative;
      overflow: hidden;
    }

    .dashboard-preview::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
      opacity: 0.5;
    }

    .dp-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-5);
    }

    .dp-title {
      font-family: var(--font-display);
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--text-secondary);
    }

    .dp-live {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      font-size: var(--text-xs);
      color: var(--color-positive);
      font-weight: 600;
    }

    .dp-live-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-positive);
      animation: pulse-glow 1.5s ease-in-out infinite;
    }

    .dp-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
      margin-bottom: var(--space-5);
    }

    .dp-stat {
      background: var(--surface-3);
      border-radius: var(--radius-lg);
      padding: var(--space-4);
      border: 1px solid var(--border-subtle);
    }

    .dp-stat-val {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      margin-bottom: var(--space-1);
    }

    .dp-stat-label {
      font-size: var(--text-xs);
      color: var(--text-muted);
    }

    .dp-chart-area {
      background: var(--surface-3);
      border-radius: var(--radius-lg);
      padding: var(--space-4);
      margin-bottom: var(--space-4);
      border: 1px solid var(--border-subtle);
      height: 120px;
      position: relative;
      overflow: hidden;
    }

    .chart-svg {
      width: 100%;
      height: 100%;
    }

    .dp-tools {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }

    .dp-tool {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      background: var(--surface-3);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      padding: var(--space-3);
      cursor: pointer;
      transition: all var(--transition-fast);
    }

    .dp-tool:hover { border-color: var(--border-accent); }

    .dp-tool-icon {
      width: 32px;
      height: 32px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }

    .dp-tool-text { font-size: var(--text-xs); font-weight: 500; color: var(--text-secondary); }

    /* Floating badge */
    .floating-badge {
      position: absolute;
      top: -12px;
      right: 24px;
      background: var(--surface-4);
      border: 1px solid var(--border-accent);
      border-radius: var(--radius-full);
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-accent);
      white-space: nowrap;
      animation: fadeUp 0.6s ease 0.3s both;
    }

    /* ===== SECTION HEADERS ===== */
    .section-header { text-align: center; margin-bottom: var(--space-12); }
    .section-header h2 { margin-bottom: var(--space-4); }
    .section-header p { font-size: var(--text-lg); color: var(--text-secondary); max-width: 600px; margin: 0 auto; }

    .section-eyebrow {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-accent);
      margin-bottom: var(--space-3);
      display: block;
    }

    /* ===== CRISIS BANNER ===== */
    .crisis-banner {
      background: linear-gradient(135deg, rgba(239,68,68,0.08) 0%, rgba(245,158,11,0.06) 100%);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: var(--radius-xl);
      padding: var(--space-6) var(--space-8);
      margin-bottom: var(--space-12);
    }

    .crisis-banner-inner {
      display: flex;
      align-items: center;
      gap: var(--space-6);
      flex-wrap: wrap;
    }

    .crisis-alert {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex-shrink: 0;
    }

    .crisis-alert-icon {
      width: 36px;
      height: 36px;
      background: rgba(239,68,68,0.15);
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    .crisis-content { flex: 1; min-width: 200px; }
    .crisis-title { font-size: var(--text-sm); font-weight: 600; color: #FCA5A5; margin-bottom: 2px; }
    .crisis-body { font-size: var(--text-xs); color: var(--text-secondary); }

    .crisis-metrics {
      display: flex;
      gap: var(--space-6);
      flex-wrap: wrap;
    }

    .crisis-metric { text-align: center; }
    .crisis-metric-val { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 700; color: #FCA5A5; display: block; }
    .crisis-metric-label { font-size: var(--text-xs); color: var(--text-muted); }

    /* ===== TOOL CATEGORIES ===== */
    .category-tabs {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex-wrap: wrap;
      margin-bottom: var(--space-8);
      padding-bottom: var(--space-4);
      border-bottom: 1px solid var(--border-subtle);
    }

    .tab-btn {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      border-radius: var(--radius-full);
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--text-secondary);
      background: none;
      border: 1px solid transparent;
      cursor: pointer;
      transition: all var(--transition-fast);
    }

    .tab-btn:hover {
      color: var(--text-primary);
      background: var(--surface-2);
      border-color: var(--border-subtle);
    }

    .tab-btn.active {
      color: var(--color-accent);
      background: var(--color-accent-subtle);
      border-color: var(--border-accent);
    }

    .tab-count {
      font-size: 10px;
      background: var(--surface-3);
      padding: 1px 6px;
      border-radius: var(--radius-full);
      color: var(--text-muted);
    }

    .tab-btn.active .tab-count { background: var(--color-accent-glow); color: var(--color-accent); }

    /* Tool Grid */
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--space-5);
    }

    .tool-card {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      padding: var(--space-5);
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      cursor: pointer;
      transition: all var(--transition-base);
      text-decoration: none;
      position: relative;
      overflow: hidden;
    }

    .tool-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--color-accent), transparent);
      opacity: 0;
      transition: opacity var(--transition-base);
    }

    .tool-card:hover {
      border-color: var(--border-accent);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 20px rgba(0,212,170,0.05);
    }

    .tool-card:hover::before { opacity: 1; }

    .tool-card.featured {
      border-color: var(--border-accent);
      background: linear-gradient(135deg, var(--surface-2) 0%, rgba(0,212,170,0.04) 100%);
    }

    .tool-card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-3);
    }

    .tool-icon {
      width: 44px;
      height: 44px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }

    .tool-badges { display: flex; flex-direction: column; gap: var(--space-1); align-items: flex-end; }

    .tool-title {
      font-family: var(--font-display);
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.3;
    }

    .tool-desc {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: 1.55;
      flex: 1;
    }

    .tool-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: var(--space-3);
      border-top: 1px solid var(--border-subtle);
      font-size: var(--text-xs);
      color: var(--text-muted);
    }

    .tool-data-source {
      display: flex;
      align-items: center;
      gap: var(--space-1);
    }

    .tool-arrow {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--surface-3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      transition: background var(--transition-fast), transform var(--transition-fast);
    }

    .tool-card:hover .tool-arrow {
      background: var(--color-accent);
      color: var(--text-inverse);
      transform: translateX(2px);
    }

    /* ===== ECONOMIC DASHBOARD SECTION ===== */
    .econ-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: var(--space-6);
      align-items: start;
    }

    @media (max-width: 900px) { .econ-grid { grid-template-columns: 1fr; } }

    .indicator-list { display: flex; flex-direction: column; gap: var(--space-3); }

    .indicator-item {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4) var(--space-5);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      transition: border-color var(--transition-fast);
    }

    .indicator-item:hover { border-color: var(--border-default); }

    .indicator-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .indicator-name { font-size: var(--text-sm); font-weight: 500; flex: 1; color: var(--text-secondary); }
    .indicator-value { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--text-primary); }
    .indicator-status { font-size: var(--text-xs); font-weight: 600; }

    .recession-meter {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      text-align: center;
    }

    .recession-score {
      font-family: var(--font-display);
      font-size: 4rem;
      font-weight: 700;
      letter-spacing: -0.04em;
      color: var(--color-warning);
      line-height: 1;
      margin: var(--space-4) 0;
    }

    .recession-label {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-bottom: var(--space-4);
    }

    .gauge-track {
      height: 8px;
      background: var(--surface-4);
      border-radius: var(--radius-full);
      overflow: hidden;
      margin-bottom: var(--space-3);
    }

    .gauge-fill {
      height: 100%;
      border-radius: var(--radius-full);
      background: linear-gradient(90deg, var(--color-positive), var(--color-warning), var(--color-danger));
      width: 48%;
    }

    .gauge-labels {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--text-muted);
    }

    /* ===== HOW IT WORKS ===== */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
      position: relative;
    }

    @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }

    .steps-grid::before {
      content: '';
      position: absolute;
      top: 28px;
      left: calc(16.66% + 28px);
